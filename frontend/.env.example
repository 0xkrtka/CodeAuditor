# CodeAuditor — Frontend Environment Variables
# Copy this file to .env.local and fill in your values

# ── REQUIRED after deploying contract ────────────────────────────────────────
NEXT_PUBLIC_AUDITOR_ADDRESS=0xYOUR_CODEAUDITOR_CONTRACT_ADDRESS
NEXT_PUBLIC_PAYMENT_TOKEN=0xYOUR_PAYMENT_TOKEN_ADDRESS

# ── Backend URL (for SSE proxy) ───────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# ── Optional: WalletConnect Project ID ───────────────────────────────────────
# Get from https://cloud.walletconnect.com
# NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id

# ── Ritual Chain Reference ────────────────────────────────────────────────────
# Chain ID:  1979
# RPC HTTP:  https://rpc.ritualfoundation.org
# RPC WSS:   wss://rpc.ritualfoundation.org/ws
# Explorer:  https://explorer.ritualfoundation.org
# Faucet:    https://faucet.ritualfoundation.org
# LLM:       0x0000000000000000000000000000000000000802
